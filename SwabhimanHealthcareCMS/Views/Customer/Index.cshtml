@model IEnumerable<SwabhimanHealthcareCMS.Models.Customer>
@{
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}
<div class="container mt-4">
    <h6>Customer > List

    </h6>
    <h2>Customers</h2>

    <div class="d-flex justify-content-end mb-3">
        <a asp-action="Create"
           class="btn btn-primary">
            Add Customer
        </a>
    </div>

    <table class="table table-dark table-hover">

        <thead>
            <tr>
                 <th>
            <input type="checkbox" id="selectAll" />
        </th>
            
                <th>Name</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Vendor</th>
                <th>Center</th>
                <th>Status</th>
                <th>Created At</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <input type="checkbox" class="rowCheckbox" value="@item.Id" />
                    </td>
                    <td>@item.Name</td>
                    <td>@item.PhoneNo</td>
                    <td>@item.Email</td>
                    <td>@item.Vendor</td>
                    <td>@item.Center</td>
                    <td>
                        <span class="badge bg-success">
                            @item.Status
                        </span>
                    </td>
                    <td>
                        @item.CreatedAt.ToString("dd-MMM-yyyy")
                    </td>

                    <td>

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-info btn-sm">
                            View
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>

                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>
