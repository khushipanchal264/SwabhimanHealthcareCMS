<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"> 
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="d-flex">
        <div style="width:400px;height:100vh;background:#111;color:white;">
            <h4 class="p-3">CMS</h4>
            <ul class="nav flex-column">
                <li>
                    <a asp-controller="Card"
                       asp-action="Index"
                       style="color:white;text-decoration:none;">
                        <i class="bi bi-card-heading"></i>
                        Cards
                    </a>
                </li>
                <br />
                <li>
                    <a asp-controller="Center"
                       asp-action="Index"
                       style="color:white;text-decoration:none;">
                        <i class="bi bi-building"></i>
                        Centers
                    </a>
                </li>
                <br />
                <a asp-controller="Customer"
                   asp-action="Index"
                   style="color:white;text-decoration:none;">
                    <i class="bi bi-people-fill"></i>
                    Customers
                </a>
                <br />
                <li>
                    <a asp-controller="User"
                       asp-action="Index"
                       style="color:white;text-decoration:none;">
                        <i class="bi bi-person-badge-fill"></i>
                        Users
                    </a>
                </li>
                <br />
                <li>
                    <a asp-controller="Vendor"
                       asp-action="Index"
                       style="color:white;text-decoration:none;">
                        <i class="bi bi-truck"></i>
                        Vendors
                    </a>
                </li>
                <hr />
                <div class="system-header" onclick="toggleSystemMenu()">
                    <span>System</span>
                    <i class="bi bi-chevron-down" id="systemArrow"></i>
                </div>
                <div id="systemMenu">
                    <li>
                        <a asp-controller="Role"
                           asp-action="Index"
                           style="color:white;text-decoration:none;">
                            <i class="bi bi-shield-lock-fill"></i>
                            Roles
                        </a>
                    </li>
                <br />
                    <li>
                        <a asp-controller="Page"
                           asp-action="Index"
                           style="color:white;text-decoration:none;">
                            <i class="bi bi-file-earmark-text-fill"></i>
                            Pages
                        </a>
                    </li>
                <br />
                    <li>
                        <a asp-controller="Menu"
                           asp-action="Index"
                           style="color:white;text-decoration:none;">
                            <i class="bi bi-list-ul"></i>
                            Header Menu
                        </a>
                    </li>
                <br />
                    <li>
                        <a asp-controller="Wallet"
                           asp-action="Index"
                           style="color:white;text-decoration:none;">
                            <i class="bi bi-wallet2"></i>
                            State Wallet Amounts
                        </a>
                    </li>

                <br />
                    <li>
                        <a asp-controller="Report"
                           asp-action="Index"
                           style="color:white;text-decoration:none;">
                            <i class="bi bi-bar-chart-fill"></i>
                            Reports
                        </a>
                    </li>
                <br>
                    <li>
                        <a asp-controller="Setting"
                           asp-action="Index"
                           style="color:white;text-decoration:none;">
                            <i class="bi bi-gear-fill"></i>
                            Settings
                        </a>
                    </li>
                </div>
            </ul>
        </div>
        <div class="main-content w-100">
    <div class="top-navbar">
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search..." />
        </div>
        <div class="top-right">
            <div class="notification">
                <i class="bi bi-bell-fill"></i>
            </div>

            @* <img src="https://i.pravatar.cc/40"
                 alt="Profile"
                 class="profile-img" /> *@

        </div>

    </div>

        <div class="container-fluid p-4">
            @RenderBody()
        </div>

    </div>
    <script>
            function toggleSystemMenu() {

                var menu = document.getElementById("systemMenu");
                var arrow = document.getElementById("systemArrow");

                if (menu.style.display === "none") {

                    menu.style.display = "block";
                    arrow.classList.remove("bi-chevron-right");
                    arrow.classList.add("bi-chevron-down");

                } else {

                    menu.style.display = "none";
                    arrow.classList.remove("bi-chevron-down");
                    arrow.classList.add("bi-chevron-right");

                }
            }
    </script>

</body>
</html>
