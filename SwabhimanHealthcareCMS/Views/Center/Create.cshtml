@model SwabhimanHealthcareCMS.Models.Center

<form asp-action="Create" method="post">

    <div class="card p-3 mb-3">
        <h4>Center Details</h4>

        <input asp-for="CenterName"
               class="form-control"
               placeholder="Center Name" />

        <input asp-for="Email"
               class="form-control mt-2"
               placeholder="Email" />

        <input asp-for="CenterCode"
               class="form-control mt-2"
               placeholder="Center Code" />

        <input asp-for="Area"
               class="form-control mt-2"
               placeholder="Area" />
    </div>

    <div class="card p-3 mb-3">
        <h4>Location Details</h4>

        <input asp-for="State"
               class="form-control"
               placeholder="State" />

        <input asp-for="District"
               class="form-control mt-2"
               placeholder="District" />

        <input asp-for="Block"
               class="form-control mt-2"
               placeholder="Block" />

        <input asp-for="Pincode"
               class="form-control mt-2"
               placeholder="Pin Code" />
    </div>

    <div class="card p-3 mb-3">
        <h4>Contact Information</h4>

        <input asp-for="Phone"
               class="form-control"
               placeholder="Contact Phone" />

        <div class="mt-3">
            <input asp-for="IsActive" type="checkbox" />
            Active
        </div>
    </div>

    <button type="submit"
            class="btn btn-primary">
        Create
    </button>

</form>